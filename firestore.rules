rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User owns their own data ───────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Meta document: profiles list + activeProfileId
      match /meta/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Per-profile data documents
      match /profiles/{profileId} {
        allow read:   if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && isValidProfileData(request.resource.data);
        allow update: if request.auth != null
                      && request.auth.uid == uid
                      && isValidProfileData(request.resource.data);
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Deny everything else ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Validation function ───────────────────────────────────
    function isValidProfileData(data) {
      return data.keys().hasAny(['entries', 'pomLog', 'settings', 'achievements',
                                  'quickNotes', 'customCats', 'lastDate', 'updatedAt'])
             && (data.get('updatedAt', 0) is int || data.get('updatedAt', 0) is float);
    }
  }
}
